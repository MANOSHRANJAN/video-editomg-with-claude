# Example env for the video-edit pipeline. Copy to `.env` and fill in.
PEXELS_API_KEY=

# Anthropic API or any Anthropic-compatible proxy (e.g. local on :8000).
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ElevenLabs Scribe for word-level transcription. If set, the pipeline
# uses Scribe; otherwise it falls back to local Whisper in .venv.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2
